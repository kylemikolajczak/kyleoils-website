---
import BaseLayout from './BaseLayout.astro';
import type { Locale } from '../data/locales';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
}

const { title, description, lang = 'de' } = Astro.props;
---

<BaseLayout title={title} description={description} {lang}>
  <div class="page-shell"><slot /></div>
</BaseLayout>

<style>
  .page-shell { min-height: 50vh; }
</style>
