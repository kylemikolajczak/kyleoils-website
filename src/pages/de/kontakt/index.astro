---
import ComplianceNote from '../../../components/compliance/ComplianceNote.astro';
import Button from '../../../components/global/Button.astro';
import HeroSplit from '../../../components/sections/HeroSplit.astro';
import SectionIntro from '../../../components/sections/SectionIntro.astro';
import StepList from '../../../components/sections/StepList.astro';
import PageLayout from '../../../layouts/PageLayout.astro';
import { contactLinks, socialLinks } from '../../../data/externalLinks';

const contactSteps = [
  {
    title: '1. Du meldest dich bei mir.',
    paragraphs: [],
  },
  {
    title: '2. Wir sprechen über deine Situation und deine Fragen.',
    paragraphs: [],
  },
  {
    title: '3. Gemeinsam schauen wir, welche Möglichkeiten sinnvoll sein könnten.',
    paragraphs: [],
  },
  {
    title: '4. Danach entscheidest du ganz in Ruhe, wie du weitergehen möchtest.',
    paragraphs: [],
  },
];

const helpTopics = [
  'doTERRA kennenlernen möchtest',
  'unsicher bist, womit du starten sollst',
  'Fragen zu ätherischen Ölen hast',
  'eine einfache Routine für deinen Alltag suchst',
  'mehr über ein bestimmtes Produkt wissen möchtest',
  'bereits doTERRA-Produkte hast, sie aber kaum nutzt',
  'ein offizielles doTERRA Kundenkonto besprechen möchtest',
  'dich für Workshops oder Öl-Abende interessierst',
  'eine Kooperation anfragen möchtest',
  'mehr über die Business-Möglichkeit erfahren willst',
];

const contactOptions = [
  {
    title: 'WhatsApp',
    copy: 'Der einfachste Weg ist eine kurze Nachricht per WhatsApp.',
    href: contactLinks.whatsapp.href,
    label: 'WhatsApp starten',
  },
  {
    title: 'Direkt anrufen',
    copy: contactLinks.phone.label,
    href: contactLinks.phone.href,
    label: 'Telefonisch kontaktieren',
  },
  {
    title: 'E-Mail schreiben',
    copy: contactLinks.email.label,
    href: contactLinks.email.href,
    label: 'E-Mail schreiben',
  },
  {
    title: 'Persönliche Beratung im Landkreis Lüneburg',
    copy: 'Landkreis Lüneburg',
    href: '/de/beratung/',
    label: 'Beratungsgespräch anfragen',
  },
  {
    title: 'Videocall',
    copy: '',
    href: '/de/beratung/',
    label: 'Videocall anfragen',
  },
];
---

<PageLayout
  title="Kontakt – Kyle Daniel Mikolajczak"
  description="Du musst noch nicht wissen, welches Öl, welches Starter-Set oder welche Routine die richtige ist."
>
  <HeroSplit
    title="Lass uns einfach sprechen"
    primaryHref={contactLinks.whatsapp.href}
    primaryLabel="WhatsApp starten"
    secondaryHref="/de/beratung/"
    secondaryLabel="Kostenloses Beratungsgespräch anfragen"
    imageSrc="/assets/images/about/contact-kyle-horse.jpg"
    imageAlt="Kyle mit einem Pferd in der Natur"
    imageWidth={1132}
    imageHeight={1390}
    imagePosition="50% 52%"
  >
    <p>Du musst noch nicht wissen, welches Öl, welches Starter-Set oder welche Routine die richtige ist.</p>
    <p>Die Kontaktaufnahme dient zuerst dazu, Fragen zu stellen, Orientierung zu bekommen und gemeinsam herauszufinden, was sinnvoll sein könnte.</p>
    <p>Kein Verkaufsdruck.</p>
  </HeroSplit>

  <section class="section section--cream">
    <div class="container">
      <SectionIntro title="So läuft die Beratung ab" />
      <StepList steps={contactSteps} />
    </div>
  </section>

  <section class="section">
    <div class="container split-copy">
      <div>
        <SectionIntro title="Wobei ich dir helfen kann">
          <p>Du kannst dich bei mir melden, wenn du:</p>
        </SectionIntro>
        <ul class="check-list">
          {helpTopics.map((topic) => <li>{topic}</li>)}
        </ul>
      </div>
      <div class="calm-panel">
        <h2>Kein Druck. Keine Verpflichtung.</h2>
        <p>Du musst nach deiner Anfrage nichts kaufen.</p>
        <p>Du musst kein Kundenkonto eröffnen.</p>
        <p>Du musst dich auch nicht sofort entscheiden.</p>
        <p>Der erste Kontakt ist dafür da, dass du Klarheit bekommst und ein Gefühl dafür entwickelst, ob die doTERRA-Produktwelt und meine Begleitung zu dir passen.</p>
      </div>
    </div>
  </section>

  <section class="section section--sage">
    <div class="container">
      <SectionIntro title="So kannst du mich erreichen">
        <p>Ich antworte in der Regel innerhalb von 24 Stunden.</p>
      </SectionIntro>
      <div class="contact-grid">
        {contactOptions.map((option) => (
          <article class="contact-card">
            <h3>{option.title}</h3>
            {option.copy && <p>{option.copy}</p>}
            <a href={option.href}>{option.label}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container details-layout">
      <div>
        <SectionIntro title="Kontaktdaten" />
        <dl class="contact-details">
          <div>
            <dt>Name</dt>
            <dd>Kyle Daniel Mikolajczak</dd>
          </div>
          <div>
            <dt>Telefon</dt>
            <dd><a href={contactLinks.phone.href}>{contactLinks.phone.label}</a></dd>
          </div>
          <div>
            <dt>WhatsApp</dt>
            <dd><a href={contactLinks.whatsapp.href}>WhatsApp starten</a></dd>
          </div>
          <div>
            <dt>E-Mail</dt>
            <dd><a href={contactLinks.email.href}>{contactLinks.email.label}</a></dd>
          </div>
          <div>
            <dt>Standort</dt>
            <dd>Landkreis Lüneburg</dd>
          </div>
          <div>
            <dt>Antwortzeit</dt>
            <dd>Ich antworte in der Regel innerhalb von 24 Stunden.</dd>
          </div>
        </dl>
      </div>
      <aside class="qualification" aria-labelledby="qualification-title">
        <h2 id="qualification-title">Qualifikation</h2>
        <ul>
          <li>doTERRA Wellness Advocate</li>
          <li>doTERRA Europe Essential Oils Specialist</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container social-layout">
      <SectionIntro title="Social Media" />
      <div class="social-links">
        <a href={socialLinks.facebook.href} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14 8h3V4h-3c-3 0-5 2-5 5v2H6v4h3v7h4v-7h3l1-4h-4V9c0-.6.4-1 1-1Z"></path>
          </svg>
          <span>Facebook</span>
        </a>
        <a href={socialLinks.linkedin.href} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.5 8.5H3V21h3.5V8.5ZM4.8 3A2.1 2.1 0 1 0 5 7.2 2.1 2.1 0 0 0 4.8 3ZM21 14.1c0-3.8-2-5.9-4.8-5.9-2.2 0-3.2 1.2-3.8 2.1V8.5H9V21h3.5v-6.2c0-1.6.3-3.2 2.3-3.2s2 1.9 2 3.3V21H21v-6.9Z"></path>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-cta__inner">
      <div>
        <h2>Du musst dich heute noch nicht entscheiden.</h2>
        <p>Wenn du Fragen hast oder einfach Orientierung möchtest, freue ich mich auf deine Nachricht.</p>
      </div>
      <div class="final-cta__actions">
        <Button href={contactLinks.whatsapp.href}>WhatsApp starten</Button>
        <Button href="/de/beratung/" variant="secondary">Beratungsgespräch anfragen</Button>
        <Button href={contactLinks.phone.href} variant="secondary">Telefonisch kontaktieren</Button>
      </div>
    </div>
  </section>

  <section class="compliance-section">
    <div class="container">
      <ComplianceNote>
        <h2>Kurzer Hinweis</h2>
        <p>Meine Beratung ersetzt keine medizinische Diagnose oder Behandlung.<br />Ich gebe keine Heilversprechen und mache keine medizinischen Aussagen.</p>
        <p>Mein Fokus liegt auf verständlicher Orientierung, natürlichen Alltagsroutinen, hochwertiger Produktinformation und persönlicher Begleitung.</p>
        <p>Wenn du gesundheitliche Beschwerden hast oder medizinische Fragen klären möchtest, wende dich bitte an einen Arzt, Heilpraktiker oder eine entsprechend qualifizierte Fachperson.</p>
      </ComplianceNote>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-64) 0; }
  .section--cream { background: var(--color-soft-cream); }
  .section--sage { background: rgb(168 184 160 / 20%); }
  .split-copy,
  .details-layout { display: grid; gap: var(--space-48); }
  .check-list { display: grid; gap: var(--space-16); margin: 0; padding: 0; list-style: none; color: var(--color-text-secondary); }
  .check-list li { position: relative; padding-left: var(--space-32); }
  .check-list li::before { content: ''; position: absolute; left: 0; top: .72em; width: 11px; height: 11px; border-radius: 50%; background: var(--color-sage-green); }
  .calm-panel { align-self: start; padding: var(--space-32); border-radius: var(--radius-section); background: var(--color-deep-forest); color: var(--color-text-inverted); }
  .calm-panel h2 { margin: 0 0 var(--space-20); font-size: var(--font-size-h2-mobile); line-height: var(--line-height-heading); }
  .calm-panel p { margin: 0 0 var(--space-16); color: var(--color-linen); }
  .calm-panel p:last-child { margin-bottom: 0; }
  .contact-grid { display: grid; gap: var(--space-20); }
  .contact-card { min-height: 230px; display: flex; flex-direction: column; align-items: flex-start; padding: var(--space-24); border: 1px solid rgb(216 199 173 / 65%); border-radius: var(--radius-card); background: var(--color-warm-white); box-shadow: var(--shadow-card); }
  .contact-card h3 { margin: 0 0 var(--space-12); font-size: var(--font-size-h3-mobile); line-height: 1.2; }
  .contact-card p { margin: 0 0 var(--space-24); overflow-wrap: anywhere; color: var(--color-text-secondary); }
  .contact-card a { min-height: 48px; display: inline-flex; align-items: center; justify-content: center; margin-top: auto; padding: var(--space-12) var(--space-20); border: 1px solid var(--color-sand); border-radius: var(--radius-button); color: var(--color-deep-forest); font-weight: var(--font-weight-semibold); line-height: 1.2; text-align: center; text-decoration: none; }
  .contact-card a:hover { border-color: var(--color-sage-green); background: var(--color-soft-cream); }
  .contact-details { display: grid; gap: 1px; overflow: hidden; margin: 0; border: 1px solid rgb(216 199 173 / 70%); border-radius: var(--radius-card); background: var(--color-sand); }
  .contact-details div { display: grid; gap: var(--space-4); padding: var(--space-20); background: var(--color-warm-white); }
  .contact-details dt { color: var(--color-text-muted); font-size: var(--font-size-small); font-weight: var(--font-weight-semibold); }
  .contact-details dd { margin: 0; overflow-wrap: anywhere; color: var(--color-text-secondary); }
  .contact-details a { color: var(--color-deep-forest); }
  .qualification { align-self: start; padding: var(--space-32); border-radius: var(--radius-section); background: var(--color-soft-cream); }
  .qualification h2 { margin: 0 0 var(--space-24); font-size: var(--font-size-h3-mobile); line-height: 1.25; }
  .qualification ul { display: grid; gap: var(--space-16); margin: 0; padding: 0; list-style: none; color: var(--color-text-secondary); }
  .qualification li { padding-top: var(--space-16); border-top: 1px solid var(--color-sand); }
  .social-layout :global(.section-intro) { margin-bottom: var(--space-24); }
  .social-links { display: flex; flex-wrap: wrap; gap: var(--space-16); }
  .social-links a { min-height: 52px; display: inline-flex; align-items: center; gap: var(--space-12); padding: var(--space-12) var(--space-20); border: 1px solid var(--color-sand); border-radius: var(--radius-button); color: var(--color-deep-forest); font-weight: var(--font-weight-semibold); text-decoration: none; }
  .social-links a:hover { border-color: var(--color-sage-green); background: var(--color-warm-white); }
  .social-links svg { width: 22px; height: 22px; fill: currentColor; }
  .final-cta { padding: var(--space-64) 0; }
  .final-cta__inner { display: grid; gap: var(--space-32); padding: var(--space-40) var(--space-24); border-radius: var(--radius-section); background: var(--color-deep-forest); color: var(--color-text-inverted); }
  .final-cta h2 { max-width: var(--container-text); margin: 0 0 var(--space-20); font-size: var(--font-size-h2-mobile); line-height: var(--line-height-heading); }
  .final-cta p { max-width: var(--container-text); margin: 0; color: var(--color-linen); }
  .final-cta__actions { display: flex; flex-direction: column; gap: var(--space-16); }
  .final-cta :global(.button--primary) { border-color: var(--color-warm-white); background: var(--color-warm-white); color: var(--color-deep-forest); }
  .final-cta :global(.button--secondary) { color: var(--color-warm-white); }
  .compliance-section { padding: 0 0 var(--space-80); }
  .compliance-section :global(h2) { margin: 0 0 var(--space-12); font-size: var(--font-size-body-mobile); }
  .compliance-section :global(p + p) { margin-top: var(--space-12); }
  @media (min-width: 600px) {
    .final-cta__actions { flex-direction: row; flex-wrap: wrap; }
  }
  @media (min-width: 768px) {
    .section { padding-block: var(--space-96); }
    .contact-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-24); }
    .contact-card { padding: var(--space-32); }
    .contact-details div { grid-template-columns: minmax(120px, .35fr) minmax(0, 1fr); gap: var(--space-24); }
    .final-cta { padding-block: var(--space-80); }
    .final-cta__inner { padding: var(--space-64); }
  }
  @media (min-width: 1024px) {
    .section { padding-block: var(--space-120); }
    .split-copy,
    .details-layout { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-80); align-items: start; }
    .contact-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .calm-panel h2,
    .final-cta h2 { font-size: var(--font-size-h2-desktop); }
  }
</style>
