---
interface Props { label?: string; }
const { label = 'Hinweis' } = Astro.props;
---

<aside class="compliance-note" aria-label={label}>
  <slot />
</aside>

<style>
  .compliance-note { max-width: var(--container-text); padding: var(--space-24); border: 1px solid var(--color-sand); border-radius: var(--radius-card); background: var(--color-soft-cream); color: var(--color-text-secondary); font-size: var(--font-size-small); line-height: var(--line-height-small); }
  .compliance-note :global(p) { margin: 0; }
</style>
