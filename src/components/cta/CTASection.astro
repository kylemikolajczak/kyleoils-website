---
import CTAGroup from './CTAGroup.astro';

interface Props {
  title: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}
const { title, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---

<section class="cta-section">
  <div class="container cta-section__inner">
    <div>
      <h2>{title}</h2>
      <div class="cta-section__copy"><slot /></div>
    </div>
    <CTAGroup {primaryHref} {primaryLabel} {secondaryHref} {secondaryLabel} />
  </div>
</section>

<style>
  .cta-section { padding: var(--space-64) 0; }
  .cta-section__inner { display: grid; gap: var(--space-32); padding: var(--space-40) var(--space-24); border-radius: var(--radius-section); background: var(--color-deep-forest); color: var(--color-text-inverted); }
  h2 { max-width: var(--container-text); margin: 0 0 var(--space-20); font-size: var(--font-size-h2-mobile); line-height: var(--line-height-heading); }
  .cta-section__copy { max-width: var(--container-text); color: var(--color-linen); }
  .cta-section__copy :global(p) { margin: 0 0 var(--space-12); }
  .cta-section__copy :global(p:last-child) { margin-bottom: 0; }
  .cta-section :global(.button--primary) { border-color: var(--color-warm-white); background: var(--color-warm-white); color: var(--color-deep-forest); }
  .cta-section :global(.button--secondary) { color: var(--color-warm-white); }
  @media (min-width: 768px) { .cta-section { padding-block: var(--space-80); } .cta-section__inner { padding: var(--space-64); } }
  @media (min-width: 1024px) { h2 { font-size: var(--font-size-h2-desktop); } }
</style>
